{
  "name": "@anby/manifest-schema",
  "version": "0.1.1",
  "description": "JSON Schema, TypeScript types, and runtime validator for the Anby Platform app manifest",
  "keywords": [
    "anby",
    "anby-platform",
    "manifest",
    "json-schema",
    "validator",
    "sdk"
  ],
  "license": "MIT",
  "author": "ANBY",
  "homepage": "https://github.com/bravebits-labs/anby-platform-packages#readme",
  "bugs": {
    "url": "https://github.com/bravebits-labs/anby-platform-packages/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bravebits-labs/anby-platform-packages.git",
    "directory": "packages/manifest-schema"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && node ../fixup-dual.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
