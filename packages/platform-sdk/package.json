{
  "name": "@anby/platform-sdk",
  "version": "0.8.1",
  "description": "Runtime SDK for building services and apps that plug into the Anby Platform — auth, events, config",
  "keywords": [
    "anby",
    "anby-platform",
    "sdk",
    "auth",
    "events",
    "platform"
  ],
  "license": "MIT",
  "author": "ANBY",
  "homepage": "https://github.com/bravebits-labs/anby-platform-packages#readme",
  "bugs": {
    "url": "https://github.com/bravebits-labs/anby-platform-packages/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bravebits-labs/anby-platform-packages.git",
    "directory": "packages/platform-sdk"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./vite": {
      "types": "./dist/cjs/vite/index.d.ts",
      "import": "./dist/esm/vite/index.js",
      "require": "./dist/cjs/vite/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && node ../fixup-dual.mjs",
    "prepublishOnly": "npm run build",
    "test": "vitest"
  },
  "dependencies": {
    "@anby/contracts": "^0.1.1",
    "@anby/manifest-schema": "^0.1.1",
    "ajv": "^8.18.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "ioredis-mock": "^8.13.1",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
